{
  "name": "offroad",
  "version": "0.1.0",
  "description": "A modern 3D top-down off-road racing game built with Babylon.js and Havok Physics",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:raw && npm run build:optimize",
    "build:raw": "vite build",
    "build:optimize": "node scripts/optimizeDistAssets.js",
    "preview": "vite preview",
    "check:terrain": "node scripts/check-terrain.mjs",
    "check:panels": "node scripts/check-panel-bindings.mjs"
  },
  "dependencies": {
    "@babylonjs/core": "^8.0.0",
    "@babylonjs/havok": "^1.3.0",
    "@babylonjs/loaders": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "bootstrap-icons": "^1.13.1",
    "fflate": "^0.8.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "ffmpeg-static": "^5.3.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.5",
    "vite": "^6.2.0"
  }
}
